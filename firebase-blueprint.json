{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email", "description": "User email" },
        "displayName": { "type": "string", "description": "User's full name" },
        "role": { "type": "string", "enum": ["customer", "admin"], "description": "User role" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" }
      },
      "required": ["uid", "email", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "Information about a product in the catalog",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique product ID" },
        "name": { "type": "string", "description": "Product name" },
        "description": { "type": "string", "description": "Product description" },
        "price": { "type": "number", "description": "Product price in USD" },
        "category": { "type": "string", "description": "Product category (e.g., Electronics, Fashion)" },
        "image": { "type": "string", "format": "uri", "description": "Product image URL" },
        "stock": { "type": "integer", "description": "Available stock quantity" },
        "rating": { "type": "number", "description": "Average rating" }
      },
      "required": ["name", "price", "category", "image", "stock"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique order ID" },
        "userId": { "type": "string", "description": "UID of the user who placed the order" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "integer" }
            }
          }
        },
        "totalAmount": { "type": "number", "description": "Total order amount" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "totalAmount", "status", "createdAt"]
    },
    "Review": {
      "title": "Review",
      "description": "Product review from a user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "userId", "rating", "comment", "createdAt"]
    },
    "Cart": {
      "title": "Cart",
      "description": "User shopping cart state",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "quantity": { "type": "integer" }
            }
          }
        },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "User profiles" },
    "/products/{productId}": { "schema": "Product", "description": "Product catalog" },
    "/orders/{orderId}": { "schema": "Order", "description": "Customer orders" },
    "/reviews/{reviewId}": { "schema": "Review", "description": "Product reviews" },
    "/carts/{userId}": { "schema": "Cart", "description": "Shopping carts" }
  }
}
